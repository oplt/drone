DATABASE_URL=postgresql+asyncpg://drone:change-me@localhost:5432/drone
SETTINGS_VAULT_KEY=generate-with-backend.core.security.secrets:Vault.generate_key
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_EMAILS=admin@example.com
ADMIN_DOMAINS=

GOOGLE_MAPS_API_KEY=replace-me
LLM_PROVIDER=ollama
LLM_API_BASE=http://localhost:11434/api/generate
LLM_API_KEY=
LLM_MODEL=deepseek-r1:8b

DRONE_CONN=udp:127.0.0.1:14550
DRONE_CONN_MAVPROXY=udp:127.0.0.1:14551
HEARTBEAT_TIMEOUT=5.0

MQTT_BROKER=127.0.0.1
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=
MQTT_USE_TLS=0
MQTT_CA_CERTS=/run/secrets/mqtt_ca.crt

OPCUA_ENDPOINT=opc.tcp://0.0.0.0:4840/freeopcua/server/
OPCUA_SECURITY_POLICY=Basic256Sha256
OPCUA_CERT_PATH=/run/secrets/opcua_cert.pem
OPCUA_KEY_PATH=/run/secrets/opcua_key.pem

RASPBERRY_IP=127.0.0.1
RASPBERRY_USER=operator
RASPBERRY_HOST=raspberrypi.local
RASPBERRY_PASSWORD=replace-me
SSH_KEY_PATH=/run/secrets/id_rsa
RASPBERRY_STREAMING_SCRIPT_PATH=/opt/raspberry/pi_camera_server.py

BATTERY_CAPACITY_WH=77
CRUISE_POWER_W=180
CRUISE_SPEED_MPS=8
ENERGY_RESERVE_FRAC=0.2

ALERTS_ENABLED=1
DEBUG_ROUTES_ENABLED=0
DB_AUTO_CREATE=0
ORCHESTRATOR_SHADOW_MODE=0
DRONE_RUNTIME_LOG_ROOT=backend/storage/logs
DRONE_RUNTIME_LOG_RETENTION_DAYS=14
RUNTIME_LOG_CLEANUP_INTERVAL_S=86400

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_PHOTOGRAMMETRY_QUEUE=photogrammetry
MAPPING_JOB_QUEUE_BACKEND=celery

PHOTOGRAMMETRY_DRONE_SYNC_DIR=backend/storage/drone_sync
PHOTOGRAMMETRY_DRONE_CAPTURE_STAGING_DIR=backend/storage/staging
PHOTOGRAMMETRY_INPUTS_DIR=backend/storage/mapping_jobs_inputs
PHOTOGRAMMETRY_STORAGE_DIR=backend/storage/mapping
PHOTOGRAMMETRY_STORAGE_BASE_URL=/mapping-assets
PHOTOGRAMMETRY_ASSET_SIGNING_SECRET=replace-with-a-dedicated-secret
PHOTOGRAMMETRY_3DTILES_CMD=

WAREHOUSE_BRIDGE_FLOW=disabled
# Preflight snapshot cache (stale-while-revalidate; sub-second UI when warm)
WAREHOUSE_PREFLIGHT_SNAPSHOT_TTL_S=10
WAREHOUSE_PREFLIGHT_CACHE_REFRESH_STALE_MS=3000
WAREHOUSE_PREFLIGHT_REDIS_CACHE=1
WAREHOUSE_PREFLIGHT_REDIS_TTL_S=60
WAREHOUSE_PREFLIGHT_REDIS_RETRY_BACKOFF_S=5
WAREHOUSE_AUTOPILOT_SAMPLE_TIMEOUT_S=1.0
WAREHOUSE_AUTOPILOT_SAMPLE_CACHE_S=2.0
WAREHOUSE_SCAN_PREFLIGHT_FORCE_FIRST=0
WAREHOUSE_FLIGHT_AUTOPILOT_TELEMETRY_TIMEOUT_S=1.0
# Flight readiness state hysteresis (consecutive samples before promote/demote)
WAREHOUSE_FLIGHT_PROMOTE_SAMPLES=3
WAREHOUSE_FLIGHT_DEMOTE_SAMPLES=2
WAREHOUSE_CAPTURE_ARTIFACT_WAIT_S=45
# WAREHOUSE_RECORD_SNAPSHOT_ON_STOP=1
WAREHOUSE_TAKEOFF_ODOMETRY_MAX_AGE_S=2.0
WAREHOUSE_RUNTIME_STARTUP_GRACE_S=60
WAREHOUSE_RUNTIME_ODOMETRY_STALE_S=2
WAREHOUSE_RUNTIME_VSLAM_RECOVERY_GRACE_S=4
WAREHOUSE_ODOMETRY_MAX_AGE_S=2.0

WAREHOUSE_FLIGHT_REQUIRE_MAVLINK=0
WAREHOUSE_SCAN_POSTPROCESS_CMD=
WAREHOUSE_TAKEOFF_READINESS_WAIT_S=10
WAREHOUSE_PREFLIGHT_PERCEPTION_WAIT_S=20
WAREHOUSE_PREFLIGHT_CHECK_INTERVAL_S=0.5
WAREHOUSE_READINESS_POLL_S=0.5

# Warehouse flight readiness gates (preflight + autonomy start)
WAREHOUSE_IMU_MAX_AGE_MS=50
WAREHOUSE_POSE_MAX_AGE_MS=100
WAREHOUSE_DEPTH_MAX_AGE_MS=200
WAREHOUSE_RGB_MAX_AGE_MS=500
WAREHOUSE_COSTMAP_MAX_AGE_MS=500
WAREHOUSE_SLAM_REQUIRED_STABLE_MS=5000
WAREHOUSE_PERCEPTION_REQUIRED_STABLE_MS=8000
WAREHOUSE_FLIGHT_MAPPING_WAIT_S=45
WAREHOUSE_PREFLIGHT_CONSECUTIVE_CHECKS=16
WAREHOUSE_MIN_BATTERY_PERCENT=30
WAREHOUSE_MAX_COMMAND_LATENCY_MS=150
WAREHOUSE_TAKEOFF_CLEAR_RADIUS_M=1.5
WAREHOUSE_MAX_INDOOR_SPEED_MPS=1.0
# Must be >= planned scan height (cruise_alt + layer spacing). Default mission cruise_alt=4m.
WAREHOUSE_MAX_INDOOR_ALTITUDE_M=6.0

WEBODM_BASE_URL=http://localhost:8001
WEBODM_API_TOKEN=
WEBODM_PROJECT_ID=1
WEBODM_MOCK_MODE=1
