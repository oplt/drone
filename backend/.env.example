DATABASE_URL=postgresql+asyncpg://drone:change-me@localhost:5432/drone
SETTINGS_VAULT_KEY=generate-with-backend.core.security.secrets:Vault.generate_key
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_EMAILS=admin@example.com
ADMIN_DOMAINS=

GOOGLE_MAPS_API_KEY=replace-me
LLM_PROVIDER=ollama
LLM_API_BASE=http://localhost:11434/api/generate
LLM_API_KEY=
LLM_MODEL=deepseek-r1:8b

DRONE_CONN=udp:127.0.0.1:14550
DRONE_CONN_MAVPROXY=udp:127.0.0.1:14551
HEARTBEAT_TIMEOUT=5.0

MQTT_BROKER=127.0.0.1
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=
MQTT_USE_TLS=0
MQTT_CA_CERTS=/run/secrets/mqtt_ca.crt

OPCUA_ENDPOINT=opc.tcp://0.0.0.0:4840/freeopcua/server/
OPCUA_SECURITY_POLICY=Basic256Sha256
OPCUA_CERT_PATH=/run/secrets/opcua_cert.pem
OPCUA_KEY_PATH=/run/secrets/opcua_key.pem

RASPBERRY_IP=127.0.0.1
RASPBERRY_USER=operator
RASPBERRY_HOST=raspberrypi.local
RASPBERRY_PASSWORD=replace-me
SSH_KEY_PATH=/run/secrets/id_rsa
RASPBERRY_STREAMING_SCRIPT_PATH=/opt/raspberry/pi_camera_server.py

BATTERY_CAPACITY_WH=77
CRUISE_POWER_W=180
CRUISE_SPEED_MPS=8
ENERGY_RESERVE_FRAC=0.2

ALERTS_ENABLED=1
DEBUG_ROUTES_ENABLED=0
DB_AUTO_CREATE=0
ORCHESTRATOR_SHADOW_MODE=0

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_PHOTOGRAMMETRY_QUEUE=photogrammetry
MAPPING_JOB_QUEUE_BACKEND=celery

PHOTOGRAMMETRY_DRONE_SYNC_DIR=backend/storage/drone_sync
PHOTOGRAMMETRY_DRONE_CAPTURE_STAGING_DIR=backend/storage/staging
PHOTOGRAMMETRY_INPUTS_DIR=backend/storage/mapping_jobs_inputs
PHOTOGRAMMETRY_STORAGE_DIR=backend/storage/mapping
PHOTOGRAMMETRY_STORAGE_BASE_URL=/mapping-assets
PHOTOGRAMMETRY_ASSET_SIGNING_SECRET=replace-with-a-dedicated-secret
PHOTOGRAMMETRY_3DTILES_CMD=

WEBODM_BASE_URL=http://localhost:8001
WEBODM_API_TOKEN=
WEBODM_PROJECT_ID=1
WEBODM_MOCK_MODE=1
