POSTGRES_PASSWORD=replace-with-a-local-password
MINIO_ROOT_USER=replace-with-a-local-user
MINIO_ROOT_PASSWORD=replace-with-a-local-password
DATABASE_URL=postgresql+asyncpg://drone:replace-with-a-local-password@localhost:5432/drone
SETTINGS_VAULT_KEY=generate-with-backend.core.security.secrets:Vault.generate_key
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_EMAILS=admin@example.com
ADMIN_DOMAINS=

GOOGLE_MAPS_API_KEY=replace-me
LLM_PROVIDER=ollama
LLM_API_BASE=http://localhost:11434/api/generate
LLM_API_KEY=
LLM_MODEL=deepseek-r1:8b

DRONE_CONN=udp:127.0.0.1:14550
DRONE_CONN_MAVPROXY=udp:127.0.0.1:14551
MISSION_TELEMETRY_STARTUP_GRACE_S=1.0
HEARTBEAT_TIMEOUT=5.0

MQTT_BROKER=127.0.0.1
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=
MQTT_USE_TLS=0
# Sensor triggers: allow GPS/webhook coordinates slightly outside the saved polygon.
PATROL_SENSOR_TRIGGER_GEOFENCE_TOLERANCE_M=75

OPCUA_ENDPOINT=opc.tcp://0.0.0.0:4840/freeopcua/server/
OPCUA_SECURITY_POLICY=Basic256Sha256
OPCUA_CERT_PATH=/run/secrets/opcua_cert.pem
OPCUA_KEY_PATH=/run/secrets/opcua_key.pem

RASPBERRY_IP=127.0.0.1
RASPBERRY_USER=operator
RASPBERRY_HOST=raspberrypi.local
RASPBERRY_PASSWORD=replace-me
SSH_KEY_PATH=/run/secrets/id_rsa
RASPBERRY_STREAMING_SCRIPT_PATH=/opt/raspberry/pi_camera_server.py

BATTERY_CAPACITY_WH=77
CRUISE_POWER_W=180
CRUISE_SPEED_MPS=8
ENERGY_RESERVE_FRAC=0.2

ALERTS_ENABLED=1
DEBUG_ROUTES_ENABLED=0
DB_AUTO_CREATE=0
ORCHESTRATOR_SHADOW_MODE=0
DRONE_RUNTIME_LOG_ROOT=backend/storage/logs
DRONE_RUNTIME_LOG_RETENTION_DAYS=14
RUNTIME_LOG_CLEANUP_INTERVAL_S=86400

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_PHOTOGRAMMETRY_QUEUE=photogrammetry
MAPPING_JOB_QUEUE_BACKEND=celery

PHOTOGRAMMETRY_DRONE_SYNC_DIR=backend/storage/drone_sync
PHOTOGRAMMETRY_DRONE_CAPTURE_STAGING_DIR=backend/storage/staging
PHOTOGRAMMETRY_INPUTS_DIR=backend/storage/mapping_jobs_inputs
PHOTOGRAMMETRY_STORAGE_DIR=backend/storage/mapping
PHOTOGRAMMETRY_STORAGE_BASE_URL=/mapping-assets
PHOTOGRAMMETRY_ASSET_SIGNING_SECRET=replace-with-a-dedicated-secret
PHOTOGRAMMETRY_3DTILES_CMD=

# ROS 2 domain for warehouse bridge probes (must match sim / ros2 shell)
ROS_DOMAIN_ID=0

# Sim video (Gazebo UDP stream)
DRONE_VIDEO_SOURCE_SIM=udp://127.0.0.1:5600
DRONE_VIDEO_USE_SIM=0

# Warehouse sim — topic names live in ros2_ws/.../warehouse_bridge.yaml only
WAREHOUSE_BRIDGE_FLOW=disabled
WAREHOUSE_SIM_MODE=0
WAREHOUSE_ROS2_WS=ros2_ws
WAREHOUSE_BRIDGE_STARTUP_GRACE_S=3.0
WAREHOUSE_ROS_CAPTURE_ROOT=backend/storage/warehouse_ros
WAREHOUSE_CAPTURE_ARTIFACT_WAIT_S=45
WAREHOUSE_SCAN_POSTPROCESS_CMD=
WAREHOUSE_MAX_INDOOR_ALTITUDE_M=6.0
WAREHOUSE_TAKEOFF_READINESS_WAIT_S=10
WAREHOUSE_FLIGHT_MAPPING_WAIT_S=45
WAREHOUSE_PREFLIGHT_WAIT_NVBLOX=0
WAREHOUSE_LIVE_MAP_INGEST_TOKEN=dev-live-map-ingest

WEBODM_BASE_URL=http://localhost:8001
WEBODM_API_TOKEN=
WEBODM_PROJECT_ID=1
WEBODM_MOCK_MODE=1

# Observability (OpenTelemetry traces, Prometheus metrics, Grafana/Tempo)
OBSERVABILITY_ENABLED=true
OTEL_SERVICE_NAME=drone-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
OTEL_ENVIRONMENT=local
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=none
PROMETHEUS_METRICS_ENABLED=true
PROMETHEUS_METRICS_PATH=/metrics
LOG_FORMAT=json
GRAFANA_PUBLIC_URL=http://127.0.0.1:3000
PROMETHEUS_PUBLIC_URL=http://127.0.0.1:9090
TEMPO_PUBLIC_URL=http://127.0.0.1:3200
WAREHOUSE_STRUCTURE_MAX_BINS_PER_RACK_FACE=8
WAREHOUSE_STRUCTURE_MIN_TARGET_SPACING_M=0.75
WAREHOUSE_STRUCTURE_REVIEW_CLEARANCE_M=0.10

# Outdoor weather preflight (Open-Meteo primary; KMI/RMI WFS for Belgium cross-check)
WEATHER_PREFLIGHT_ENABLED=true
WEATHER_CACHE_TTL_S=300
WEATHER_API_FAIL_POLICY=warn
WIND_MAX=12.0
GUST_MAX=15.0
WEATHER_MAX_PRECIP_MM=0.5
WEATHER_MIN_VISIBILITY_M=3000
WEATHER_MAX_CLOUD_COVER_PCT=90
WEATHER_MIN_TEMP_C=-10
WEATHER_MAX_TEMP_C=40
WEATHER_BLOCKED_CODES=45,48,56,57,65,67,75,77,82,85,86,95,96,99
WEATHER_WARN_CODES=51,53,55,61,63,80,81
KMI_RMI_VALIDATION_ENABLED=true
KMI_RMI_MAX_OBS_AGE_HOURS=6
KMI_RMI_WIND_DELTA_WARN_MPS=4.0
KMI_RMI_WIND_DELTA_BLOCK_MPS=8.0
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast
KMI_RMI_WFS_BASE_URL=https://opendata.meteo.be/service/aws/ows
