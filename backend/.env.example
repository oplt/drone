DATABASE_URL=postgresql+asyncpg://drone:change-me@localhost:5432/drone
SETTINGS_VAULT_KEY=generate-with-backend.core.security.secrets:Vault.generate_key
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_EMAILS=admin@example.com
ADMIN_DOMAINS=

GOOGLE_MAPS_API_KEY=replace-me
LLM_PROVIDER=ollama
LLM_API_BASE=http://localhost:11434/api/generate
LLM_API_KEY=
LLM_MODEL=deepseek-r1:8b

DRONE_CONN=udp:127.0.0.1:14550
DRONE_CONN_MAVPROXY=udp:127.0.0.1:14551
HEARTBEAT_TIMEOUT=5.0

MQTT_BROKER=127.0.0.1
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=
MQTT_USE_TLS=0
MQTT_CA_CERTS=/run/secrets/mqtt_ca.crt

OPCUA_ENDPOINT=opc.tcp://0.0.0.0:4840/freeopcua/server/
OPCUA_SECURITY_POLICY=Basic256Sha256
OPCUA_CERT_PATH=/run/secrets/opcua_cert.pem
OPCUA_KEY_PATH=/run/secrets/opcua_key.pem

RASPBERRY_IP=127.0.0.1
RASPBERRY_USER=operator
RASPBERRY_HOST=raspberrypi.local
RASPBERRY_PASSWORD=replace-me
SSH_KEY_PATH=/run/secrets/id_rsa
RASPBERRY_STREAMING_SCRIPT_PATH=/opt/raspberry/pi_camera_server.py

BATTERY_CAPACITY_WH=77
CRUISE_POWER_W=180
CRUISE_SPEED_MPS=8
ENERGY_RESERVE_FRAC=0.2

ALERTS_ENABLED=1
DEBUG_ROUTES_ENABLED=0
DB_AUTO_CREATE=0
ORCHESTRATOR_SHADOW_MODE=0

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_PHOTOGRAMMETRY_QUEUE=photogrammetry
MAPPING_JOB_QUEUE_BACKEND=celery

PHOTOGRAMMETRY_DRONE_SYNC_DIR=backend/storage/drone_sync
PHOTOGRAMMETRY_DRONE_CAPTURE_STAGING_DIR=backend/storage/staging
PHOTOGRAMMETRY_INPUTS_DIR=backend/storage/mapping_jobs_inputs
PHOTOGRAMMETRY_STORAGE_DIR=backend/storage/mapping
PHOTOGRAMMETRY_STORAGE_BASE_URL=/mapping-assets
PHOTOGRAMMETRY_ASSET_SIGNING_SECRET=replace-with-a-dedicated-secret
PHOTOGRAMMETRY_3DTILES_CMD=

# Gazebo is started externally, e.g. gz sim -v4 -r iriswlidar_warehouse.sdf
ROS_DOMAIN_ID=42
WAREHOUSE_GAZEBO_SENSOR_WAIT_S=300
WAREHOUSE_GAZEBO_SIM=1
# Require Gazebo RGB/depth/odom to publish before ros_gz_bridge starts (default on).
WAREHOUSE_GAZEBO_REQUIRE_PUBLISHING=1
# Deep health probes Gazebo transport directly (gz topic -f) for flight gates.
WAREHOUSE_GAZEBO_PROBE_ON_HEALTH=1
WAREHOUSE_GAZEBO_PROBE_TIMEOUT_S=3
WAREHOUSE_TOPIC_PROFILE=gazebo
WAREHOUSE_RGB_TOPIC=/warehouse/front/rgbd/image
WAREHOUSE_LEFT_IMAGE_TOPIC=/warehouse/stereo/left/image
WAREHOUSE_RIGHT_IMAGE_TOPIC=/warehouse/stereo/right/image
WAREHOUSE_DEPTH_TOPIC=/warehouse/front/rgbd/depth_image
WAREHOUSE_RAW_LIDAR_TOPIC=/warehouse/front/rgbd/points
WAREHOUSE_LIDAR_POINTS_TOPIC=/scan/points
WAREHOUSE_SCAN_TOPIC=/scan
# IMU Gazebo topic (optional). Auto-discovered from `gz topic -l | grep -i imu` when unset.
# WAREHOUSE_IMU_TOPIC=
WAREHOUSE_VISUAL_SLAM_ODOM_TOPIC=/warehouse/drone/odometry
# Canonical odometry for Gazebo (aliases visual_slam_odom when set)
WAREHOUSE_ODOMETRY_TOPIC=/warehouse/drone/odometry
# Optional relay topic; not required for Gazebo basic scan unless WAREHOUSE_REQUIRE_LOCAL_ODOMETRY=1
# WAREHOUSE_LOCAL_ODOMETRY_TOPIC=/warehouse/local_odometry
WAREHOUSE_HEALTH_STARTUP_GRACE_S=60
WAREHOUSE_ROS_BRIDGE_URL=http://127.0.0.1:8088
WAREHOUSE_ROS_WS_URL=ws://127.0.0.1:8089/ws
WAREHOUSE_ROS_CAPTURE_ROOT=backend/storage/warehouse_ros
WAREHOUSE_ROS_PROFILE=gazebo
WAREHOUSE_ROS_AUTOLAUNCH=0
WAREHOUSE_CAPTURE_ARTIFACT_WAIT_S=45
WAREHOUSE_NVBLOX_EXPORT_ON_STOP=1
WAREHOUSE_NVBLOX_EXPORT_WAIT_S=20
# Gazebo: record a short rosbag snapshot when nvblox file export fails (default on for gazebo profile)
# WAREHOUSE_RECORD_SNAPSHOT_ON_STOP=1
WAREHOUSE_RECORD_SNAPSHOT_DURATION_S=5
WAREHOUSE_ROS_BRIDGE_TIMEOUT_S=3.0
WAREHOUSE_ROS_BRIDGE_DEEP_TIMEOUT_S=90.0
# auto = probe nvblox only when /nvblox_node/ topics exist; never = idle bridge health skips nvblox
WAREHOUSE_BRIDGE_HEALTH_CHECK_NVBLOX=auto
WAREHOUSE_BRIDGE_WAIT_FOR_TOPICS=1
WAREHOUSE_BRIDGE_SENSOR_WAIT_S=120
WAREHOUSE_HEALTH_BACKGROUND_PROBE=1
WAREHOUSE_HEALTH_DEEP_PROBE=0
WAREHOUSE_HEALTH_REFRESH_INTERVAL_S=8
WAREHOUSE_HEALTH_DEEP_STALE_S=20
WAREHOUSE_TOPIC_MAX_AGE_S=3.0
WAREHOUSE_TOPIC_MIN_HZ=0.5
WAREHOUSE_TOPIC_HZ_TIMEOUT_S=5.0
WAREHOUSE_TAKEOFF_ODOMETRY_MAX_AGE_S=2.0
WAREHOUSE_RUNTIME_STARTUP_GRACE_S=15
WAREHOUSE_RUNTIME_ODOMETRY_STALE_S=2
WAREHOUSE_RUNTIME_VSLAM_RECOVERY_GRACE_S=4
WAREHOUSE_RUNTIME_DEEP_HEALTH_INTERVAL_S=12
WAREHOUSE_ODOMETRY_MAX_AGE_S=2.0

# Gazebo warehouse video: prefer local UDP, not external TCP streams
DRONE_VIDEO_USE_GAZEBO=1
DRONE_VIDEO_SOURCE_GAZEBO=udp://127.0.0.1:5600
WAREHOUSE_TOPIC_PROBE_WORKERS=3
WAREHOUSE_ODOMETRY_STATE_PATH=backend/storage/warehouse_ros/latest_odometry.json
WAREHOUSE_MAVLINK_VISION_URL=udpout:127.0.0.1:14550
WAREHOUSE_SEND_VISION_POSITION=1
WAREHOUSE_SCAN_POSTPROCESS_CMD=
WAREHOUSE_CAMERA_LAUNCH_CMD=
# Leave empty for Gazebo sim — IMU is bridged by gazebo_sensor_bridge in Procfile.dev.
# Quote values that contain spaces, e.g.:
# WAREHOUSE_IMU_LAUNCH_CMD="ros2 launch mavros apm.launch fcu_url:=udp://:14550@127.0.0.1:14555"
WAREHOUSE_IMU_LAUNCH_CMD=
WAREHOUSE_IMAGE_PIPELINE_LAUNCH_CMD=
WAREHOUSE_VISUAL_SLAM_LAUNCH_CMD=
WAREHOUSE_DEPTH_LAUNCH_CMD=
WAREHOUSE_NVBLOX_LAUNCH_CMD=bash scripts/start_warehouse_nvblox.sh
WAREHOUSE_MAPPING_STACK_MODE=nvblox
WAREHOUSE_REUSE_DEV_NVBLOX=0
WAREHOUSE_FLIGHT_MAPPING_WAIT_S=30
WAREHOUSE_TAKEOFF_READINESS_WAIT_S=10
WAREHOUSE_TAKEOFF_DEEP_PROBE=0
WAREHOUSE_TAKEOFF_REQUIRE_RAW_LIDAR=0
WAREHOUSE_REQUIRE_RAW_LIDAR=0
WAREHOUSE_MAPPING_STACK_SETTLE_S=2
WAREHOUSE_NVBLOX_SENSOR_WAIT_S=120
WAREHOUSE_POINTCLOUD_TOPIC=/nvblox_node/static_esdf_pointcloud
WAREHOUSE_MESH_TOPIC=/nvblox_node/mesh
WAREHOUSE_MESH_MARKER_TOPIC=/nvblox_node/tsdf_layer_marker
WAREHOUSE_OCCUPANCY_TOPIC=/nvblox_node/static_occupancy_grid
WAREHOUSE_PREFLIGHT_PERCEPTION_WAIT_S=20
WAREHOUSE_PREFLIGHT_CHECK_INTERVAL_S=0.5
WAREHOUSE_PREFLIGHT_WAIT_NVBLOX=0
WAREHOUSE_READINESS_POLL_S=0.5
WAREHOUSE_READINESS_DEEP_INTERVAL_S=6
WAREHOUSE_TAKEOFF_REQUIRE_NVBLOX=0
WAREHOUSE_ESDF_TOPIC=/nvblox_node/static_esdf_pointcloud
WAREHOUSE_BACK_PROJECTED_DEPTH_TOPIC=/nvblox_node/back_projected_depth

# Warehouse flight readiness gates (preflight + autonomy start)
WAREHOUSE_IMU_MAX_AGE_MS=50
WAREHOUSE_POSE_MAX_AGE_MS=100
WAREHOUSE_DEPTH_MAX_AGE_MS=200
WAREHOUSE_RGB_MAX_AGE_MS=500
WAREHOUSE_COSTMAP_MAX_AGE_MS=500
WAREHOUSE_SLAM_REQUIRED_STABLE_MS=5000
WAREHOUSE_PERCEPTION_REQUIRED_STABLE_MS=8000
WAREHOUSE_PREFLIGHT_CONSECUTIVE_CHECKS=16
WAREHOUSE_MIN_BATTERY_PERCENT=30
WAREHOUSE_MAX_COMMAND_LATENCY_MS=150
WAREHOUSE_TAKEOFF_CLEAR_RADIUS_M=1.5
WAREHOUSE_MAX_INDOOR_SPEED_MPS=1.0
WAREHOUSE_MAX_INDOOR_ALTITUDE_M=3.0


WEBODM_BASE_URL=http://localhost:8001
WEBODM_API_TOKEN=
WEBODM_PROJECT_ID=1
WEBODM_MOCK_MODE=1
