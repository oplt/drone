#!/usr/bin/env bash
set -euo pipefail

URL="${1:?usage: wait-for-http URL [timeout_s]}"
TIMEOUT_S="${2:-60}"
STARTED_AT="$(date +%s)"

while true; do
  if curl -fsS "$URL" >/dev/null 2>&1; then
    exit 0
  fi

  NOW="$(date +%s)"
  if [ "$((NOW - STARTED_AT))" -ge "$TIMEOUT_S" ]; then
    echo "Timed out waiting for ${URL}" >&2
    exit 1
  fi

  sleep 1
done
