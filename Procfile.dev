redis: sh -c 'mkdir -p backend/storage/redis && exec redis-server --bind 127.0.0.1 --port ${REDIS_PORT:-6380} --save "" --appendonly no --dir backend/storage/redis'
#mqtt: sh -c 'command -v mosquitto >/dev/null 2>&1 || { echo "mosquitto is not installed. Install with: sudo apt install mosquitto"; exit 1; }; exec mosquitto -p ${MQTT_PORT:-1883}'
backend: sh -c 'if [ "${RUN_MIGRATIONS:-1}" = "1" ]; then "${APP_PYTHON:-.venv/bin/python}" -m alembic -c backend/alembic.ini upgrade head; fi; reload_args=""; if [ "${BACKEND_RELOAD:-0}" = "1" ]; then reload_args="--reload --reload-dir backend"; fi; exec "${APP_PYTHON:-.venv/bin/python}" -m uvicorn backend.entrypoints.api.app:app $reload_args --host "${APP_HOST:-localhost}" --port "${APP_PORT:-8000}"'
frontend: sh -c 'until curl -fsS "http://${APP_HOST:-localhost}:${APP_PORT:-8000}/healthz" >/dev/null 2>&1 || curl -fsS "http://${APP_HOST:-localhost}:${APP_PORT:-8000}/docs" >/dev/null 2>&1; do echo "waiting for backend..."; sleep 1; done; cd frontend && exec npm run dev -- --host "${FRONTEND_HOST:-localhost}" --port "${FRONTEND_PORT:-5173}"'
browser: sh -c 'until curl -fsS "http://${APP_HOST:-localhost}:${APP_PORT:-8000}/healthz" >/dev/null 2>&1 || curl -fsS "http://${APP_HOST:-localhost}:${APP_PORT:-8000}/docs" >/dev/null 2>&1; do echo "waiting for backend..."; sleep 1; done; until curl -fsS "http://${FRONTEND_HOST:-localhost}:${FRONTEND_PORT:-5173}" >/dev/null 2>&1; do echo "waiting for frontend..."; sleep 1; done; xdg-open "http://${FRONTEND_HOST:-localhost}:${FRONTEND_PORT:-5173}/?dev_ts=$(date +%s)" >/dev/null 2>&1 || true; tail -f /dev/null'
#llama_cpp: sh -c 'curl -fsS http://127.0.0.1:8081/v1/models >/dev/null 2>&1 && echo "llama.cpp already running on 127.0.0.1:8081, skipping..." && tail -f /dev/null || exec /home/polat/Desktop/Projects/llama.cpp/build/bin/llama-server -m /home/polat/Desktop/Projects/llama.cpp/models/Qwen_Qwen3-14B-Q4_K_M.gguf --host 127.0.0.1 --port 8081 -c 8192 --flash-attn on -ngl 999 -np 1'

default_worker: sh -c 'exec "${APP_PYTHON:-.venv/bin/python}" -m celery -A backend.entrypoints.workers.celery_app:celery_app worker --loglevel=INFO --queues=default --hostname=default@%h --concurrency="${CELERY_DEV_DEFAULT_CONCURRENCY:-2}" --without-gossip --without-mingle'
photogrammetry_worker: sh -c 'exec "${APP_PYTHON:-.venv/bin/python}" -m celery -A backend.entrypoints.workers.celery_app:celery_app worker --loglevel=INFO --queues=photogrammetry --hostname=photogrammetry@%h --concurrency="${CELERY_DEV_PHOTOGRAMMETRY_CONCURRENCY:-1}" --without-gossip --without-mingle'
video_analysis_worker: sh -c 'exec "${APP_PYTHON:-.venv/bin/python}" -m celery -A backend.entrypoints.workers.celery_app:celery_app worker --loglevel=INFO --queues=video-analysis --hostname=video-analysis@%h --concurrency="${CELERY_DEV_VIDEO_ANALYSIS_CONCURRENCY:-1}" --without-gossip --without-mingle'
warehouse_mapping_worker: sh -c 'exec "${APP_PYTHON:-.venv/bin/python}" -m celery -A backend.entrypoints.workers.celery_app:celery_app worker --loglevel=INFO --queues=warehouse-mapping --hostname=warehouse-mapping@%h --concurrency="${CELERY_DEV_WAREHOUSE_MAPPING_CONCURRENCY:-1}" --without-gossip --without-mingle'
