redis: sh -c 'redis-cli -h 127.0.0.1 -p 6379 ping >/dev/null 2>&1 && echo "Redis already running" && tail -f /dev/null || redis-server'
backend: sh -c 'alembic -c backend/alembic.ini upgrade head && uvicorn backend.entrypoints.api.app:app --reload --reload-dir backend --host 0.0.0.0 --port 8000'
default_worker: celery -A backend.entrypoints.workers.celery_app:celery_app worker --loglevel=INFO --queues=default --hostname=default@%h
photogrammetry_worker: celery -A backend.entrypoints.workers.celery_app:celery_app worker --loglevel=INFO --queues=photogrammetry --hostname=photogrammetry@%h
video_analysis_worker: celery -A backend.entrypoints.workers.celery_app:celery_app worker --loglevel=INFO --queues=video-analysis --hostname=video-analysis@%h
warehouse_mapping_worker: celery -A backend.entrypoints.workers.celery_app:celery_app worker --loglevel=INFO --queues=warehouse-mapping --hostname=warehouse-mapping@%h
frontend: cd frontend && rm -rf node_modules/.vite && npm run dev -- --force
browser: sh -c 'until curl -s http://localhost:5173 >/dev/null 2>&1; do sleep 1; done; xdg-open "http://localhost:5173/?dev_ts=$(date +%s)" >/dev/null 2>&1 || true; tail -f /dev/null'
# llama_cpp: sh -c 'curl -s http://localhost:8081/v1/models >/dev/null 2>&1 && echo "llama.cpp already running, skipping..." && tail -f /dev/null || /home/polat/Desktop/Projects/llama.cpp/build/bin/llama-server -m /home/polat/Desktop/Projects/llama.cpp/models/qwen2.5-14b-instruct-q5_k_m.gguf --host 127.0.0.1 --port 8081 -c 4096 -ngl 99 -fa -b 512 -ub 256 -t 8 --cache-type-k q8_0 --cache-type-v q8_0'
# ollama: sh -c 'curl -s http://localhost:11434/api/tags >/dev/null 2>&1 && echo "Ollama already running, skipping..." && tail -f /dev/null || ollama serve'
gazebo_sensor_bridge: bash -lc 'set -o pipefail; source /opt/ros/${ROS_DISTRO:-jazzy}/setup.bash && echo "[gazebo_sensor_bridge] start ROS_DOMAIN_ID=${ROS_DOMAIN_ID:-unset} GZ_PARTITION=${GZ_PARTITION:-unset} log_level=${WAREHOUSE_GAZEBO_BRIDGE_LOG_LEVEL:-info}" && exec ros2 run ros_gz_bridge parameter_bridge /warehouse/stereo/left/image@sensor_msgs/msg/Image@gz.msgs.Image /warehouse/stereo/left/camera_info@sensor_msgs/msg/CameraInfo@gz.msgs.CameraInfo /warehouse/stereo/right/image@sensor_msgs/msg/Image@gz.msgs.Image /warehouse/stereo/right/camera_info@sensor_msgs/msg/CameraInfo@gz.msgs.CameraInfo /warehouse/front/rgbd/image@sensor_msgs/msg/Image@gz.msgs.Image /warehouse/front/rgbd/depth_image@sensor_msgs/msg/Image@gz.msgs.Image /warehouse/front/rgbd/camera_info@sensor_msgs/msg/CameraInfo@gz.msgs.CameraInfo /warehouse/front/rgbd/points@sensor_msgs/msg/PointCloud2@gz.msgs.PointCloudPacked /scan@sensor_msgs/msg/LaserScan@gz.msgs.LaserScan /scan/points@sensor_msgs/msg/PointCloud2@gz.msgs.PointCloudPacked /world/iris_warehouse/model/iris_rplidar_rgbd/model/iris_with_standoffs/link/imu_link/sensor/imu_sensor/imu@sensor_msgs/msg/Imu@gz.msgs.IMU /warehouse/drone/odometry@nav_msgs/msg/Odometry@gz.msgs.Odometry --ros-args --log-level ${WAREHOUSE_GAZEBO_BRIDGE_LOG_LEVEL:-info}'
warehouse_bridge: bash -lc 'source /opt/ros/${ROS_DISTRO:-jazzy}/setup.bash && source "${ROS_WS_SETUP:-warehouse_ros2_ws/install/setup.bash}" && export PYTHONPATH="${PWD}/warehouse_ros2_ws/src/warehouse_mapping_bridge:${PYTHONPATH}" && echo "[warehouse_bridge] start ROS_DOMAIN_ID=${ROS_DOMAIN_ID:-unset} WAREHOUSE_ROS_BRIDGE_URL=${WAREHOUSE_ROS_BRIDGE_URL:-unset}" && exec "${WAREHOUSE_BRIDGE_PYTHON:-python3}" -m warehouse_mapping_bridge.bridge_service'
warehouse_mapping_stack: bash -lc 'source /opt/ros/${ROS_DISTRO:-jazzy}/setup.bash && source "${ROS_WS_SETUP:-warehouse_ros2_ws/install/setup.bash}" && echo "[warehouse_mapping_stack] start profile=${WAREHOUSE_ROS_PROFILE:-unset} ROS_DOMAIN_ID=${ROS_DOMAIN_ID:-unset}" && ros2 launch warehouse_mapping_bridge isaac_warehouse_mapping.launch.py'
rosbridge_ws: bash -lc 'source /opt/ros/${ROS_DISTRO:-jazzy}/setup.bash && source "${ROS_WS_SETUP:-warehouse_ros2_ws/install/setup.bash}" && echo "[rosbridge_ws] start port=9090 ROS_DOMAIN_ID=${ROS_DOMAIN_ID:-unset}" && ros2 launch rosbridge_server rosbridge_websocket_launch.xml port:=9090'
