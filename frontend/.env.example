# Leave unset for local dev: requests use the Vite proxy (/auth, /api, …) so
# httpOnly session cookies stay same-origin. Setting http://localhost:8000
# breaks login → dashboard (cookies are not stored cross-site).
# VITE_API_BASE_URL=
VITE_GOOGLE_MAPS_JAVASCRIPT_API_KEY=replace-me
VITE_GOOGLE_MAPS_MAP_ID=replace-me
VITE_CESIUM_ION_TOKEN=replace-me
